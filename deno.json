{
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "pino": "npm:pino@^10.3.1",
    "pino-pretty": "npm:pino-pretty@^13.1.3",
    "zod": "npm:zod@^4.3.6",
    "~/": "./src/"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-write --allow-read --allow-sys --allow-import ./src/server.ts",
    "dev": "deno run -A --watch ./src/server.ts"
  }
}